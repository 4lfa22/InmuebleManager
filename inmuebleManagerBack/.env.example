# =============================================
# VARIABLES DE ENTORNO - INMUEBLE MANAGER
# =============================================

# =============================================
# BASE DE DATOS
# =============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_inmuebles
DB_USER=postgres
DB_PASSWORD=postgres

# =============================================
# JWT - SEGURIDAD
# =============================================
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=mySecretKeyForInmuebleManagerApplicationSecurity12345678901234567890

# Tiempo de expiración del token en milisegundos
# 3600000 = 1 hora
# 86400000 = 24 horas
JWT_EXPIRATION=3600000

# =============================================
# SERVIDOR
# =============================================
SERVER_PORT=8080

# =============================================
# LOG
# =============================================
LOG_LEVEL=INFO
